DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-lan-ip
# Optional: collectstatic target (absolute path, or relative to project root). Default: staticfiles/
# DJANGO_STATIC_ROOT=/var/www/dbmanager/static
# Optional: path to Docker socket (default unset = SDK default)
# DOCKER_HOST=unix:///var/run/docker.sock
