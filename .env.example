DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-lan-ip
# Optional: collectstatic target (absolute path, or relative to project root). Default: staticfiles/
# DJANGO_STATIC_ROOT=/var/www/dbmanager/static
# Optional: path to Docker socket (default unset = SDK default)
# DOCKER_HOST=unix:///var/run/docker.sock

# Celery (background Docker / SQL admin jobs). Default broker is local Redis DB 0.
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# SQL import staging (web + Celery must share this path in multi-container setups)
# DJANGO_MEDIA_ROOT=/path/to/dbmanager/media
# SQL_IMPORT_MAX_UPLOAD_BYTES=1073741824
# SQL_IMPORT_MYSQL_TIMEOUT_SEC=3600
# SQL_IMPORT_ZIP_MAX_UNCOMPRESSED_BYTES=536870912
