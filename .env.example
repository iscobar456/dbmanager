DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-lan-ip
# Optional: collectstatic target (absolute path, or relative to project root). Default: staticfiles/
# DJANGO_STATIC_ROOT=/var/www/dbmanager/static
# Optional: path to Docker socket (default unset = SDK default)
# DOCKER_HOST=unix:///var/run/docker.sock

# Celery (background Docker / SQL admin jobs). Default broker is local Redis DB 0.
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Defaults: CELERY_TASK_SOFT_TIME_LIMIT=3300 / CELERY_TASK_TIME_LIMIT=3600 — import jobs override below.
# CELERY_IMPORT_SQL_TASK_SOFT_TIME_LIMIT=14400
# CELERY_IMPORT_SQL_TASK_TIME_LIMIT=14700

# SQL import staging (web + Celery must share this path in multi-container setups)
# DJANGO_MEDIA_ROOT=/path/to/dbmanager/media
# SQL_IMPORT_MAX_UPLOAD_BYTES=1073741824
# SQL_IMPORT_MYSQL_TIMEOUT_SEC (default matches CELERY_IMPORT_SQL_TASK_TIME_LIMIT if unset)
# SQL_IMPORT_MYSQL_INIT_COMMAND="SET SESSION foreign_key_checks=0; SET SESSION unique_checks=0;"
# Omit the variable entirely for that default; SQL_IMPORT_MYSQL_INIT_COMMAND= to disable.
# Import job UI: throttle DockerAdminJob updates while streaming SQL into mysql (bytes + min seconds).
# SQL_IMPORT_PROGRESS_INTERVAL_BYTES=5242880
# SQL_IMPORT_PROGRESS_MIN_INTERVAL_SEC=2
# SQL_IMPORT_ZIP_MAX_UNCOMPRESSED_BYTES=536870912
#
# Chunked SQL import (admin UI uses many small POSTs for large files). Each POST body is at most:
# SQL_IMPORT_CHUNK_SIZE_BYTES=8388608
# Django must allow at least that much in memory for the request body (default auto-set from chunk size):
# DATA_UPLOAD_MAX_MEMORY_SIZE=8388608
# SQL_IMPORT_CHUNK_THRESHOLD_BYTES=10485760
# SQL_IMPORT_CHUNK_UPLOAD_TTL_SEC=86400
# If nginx fronts Django: client_max_body_size should exceed SQL_IMPORT_CHUNK_SIZE_BYTES (e.g. 16m).
# Abandoned partial_*.{part,meta.json,lock} under media/sql_import_staging/ are removed on new init
# when older than SQL_IMPORT_CHUNK_UPLOAD_TTL_SEC; periodic manual cleanup is still fine.
